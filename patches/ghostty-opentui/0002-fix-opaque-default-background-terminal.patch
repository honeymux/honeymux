+
+    const terminal_bg = color.RGB{ .r = 0x1e, .g = 0x1e, .b = 0x1e };
+    try stream.nextSlice("\x1b[48;2;30;30;30mX");
+
+    const screen = t.screens.active;
+    const palette = &t.colors.palette.current;
+    var row_iter = screen.pages.rowIterator(.right_down, .{ .screen = .{} }, null);
+    const pin = row_iter.next().?;
+    const cells = pin.cells(.all);
+    const style = getStyleFromCell(&cells[0], pin, palette, terminal_bg);
+
+    try testing.expect(style.bg == null);
+}
