diff --git a/src/tests/render-command-cache.test.ts b/src/tests/render-command-cache.test.ts
new file mode 100644
index 00000000..6d0ab02d
--- /dev/null
+++ b/src/tests/render-command-cache.test.ts
@@ -0,0 +1,90 @@
+import { afterEach, beforeEach, describe, expect, it } from "bun:test"
+import type { RenderCommand } from "../Renderable.js"
+import { BoxRenderable } from "../renderables/Box.js"
+import { TextRenderable } from "../renderables/Text.js"
+import { createTestRenderer, type TestRenderer } from "../testing/test-renderer.js"
+
+let currentRenderer: TestRenderer
+let renderOnce: () => Promise<void>
+
+class CountingLeafBox extends BoxRenderable {
+  public updateLayoutCalls = 0
+
+  public override updateLayout(
+    deltaTime: number,
+    renderList: RenderCommand[] = [],
+    ancestorLayoutChanged: boolean = false,
+  ): void {
+    this.updateLayoutCalls++
+    super.updateLayout(deltaTime, renderList, ancestorLayoutChanged)
+  }
+}
+
+describe("Render command cache", () => {
+  beforeEach(async () => {
+    ;({ renderer: currentRenderer, renderOnce } = await createTestRenderer({
+      width: 20,
+      height: 6,
+    }))
+  })
+
+  afterEach(() => {
+    currentRenderer.destroy()
+  })
+
+  it("skips clean static descendants on unrelated rerenders", async () => {
+    const staticParent = new BoxRenderable(currentRenderer, {
+      id: "static-parent",
+      position: "absolute",
+      left: 0,
+      top: 0,
+      width: 12,
+      height: 3,
+      border: false,
+    })
+    const countedLeaf = new CountingLeafBox(currentRenderer, {
+      id: "counted-leaf",
+      position: "absolute",
+      left: 1,
+      top: 1,
+      width: 4,
+      height: 1,
+      border: false,
+    })
+    countedLeaf.add(
+      new TextRenderable(currentRenderer, {
+        id: "label",
+        content: "leaf",
+        position: "absolute",
+        left: 0,
+        top: 0,
+      }),
+    )
+    staticParent.add(countedLeaf)
+
+    const tick = new TextRenderable(currentRenderer, {
+      id: "tick",
+      content: "a",
+      position: "absolute",
+      left: 0,
+      top: 4,
+    })
+
+    currentRenderer.root.add(staticParent)
+    currentRenderer.root.add(tick)
+
+    await renderOnce()
+    const initialCalls = countedLeaf.updateLayoutCalls
+    expect(initialCalls).toBeGreaterThan(0)
+
+    tick.requestRender()
+    await renderOnce()
+    const warmedCalls = countedLeaf.updateLayoutCalls
+
+    tick.requestRender()
+    await renderOnce()
+
+    expect(warmedCalls).toBeGreaterThan(initialCalls)
+    expect(countedLeaf.updateLayoutCalls).toBe(warmedCalls)
+  })
+})
