+// =============================================================================
+// Base Palette Override
+// =============================================================================
+//
+// Consumers (e.g. an outer terminal multiplexer) can push their host
+// terminal's user-configured 0-15 ANSI palette into ghostty-vt so that
+// palette-indexed SGR codes (`\x1b[3Nm`, `\x1b[9Nm`, `\x1b[38;5;Nm` with
+// N < 16) resolve to the host's colors instead of ghostty's hardcoded
+// Tomorrow Night defaults. Without this, fg/bg hex written into spans is
+// ghostty's own palette, which silently overrides whatever the host
+// terminal would otherwise paint.
+//
+// The override is applied via `DynamicPalette.changeDefault(..)` at
+// terminal-init time, so it survives palette resets (OSC 104). Indices
+// 16-255 are left at ghostty's defaults — the standard xterm-256color
+// cube + grayscale formula matches every common host terminal byte for
+// byte, so only 0-15 need projection.
+
+var base_palette_mutex: std.Thread.Mutex = .{};
+var base_palette_override: [16]?color.RGB = .{null} ** 16;
+var base_palette_has_any: bool = false;
+
+/// Set entry `idx` (0-15) of the base palette override. Subsequent
+/// terminals (created via createTerminal/ptyToJson/ptyToText/ptyToHtml)
+/// will resolve palette index `idx` to this color instead of ghostty's
+/// default.
+fn setBasePaletteEntry(idx: u32, r: u32, g: u32, b: u32) !void {
+    if (idx >= 16) return error.InvalidIndex;
+    base_palette_mutex.lock();
+    defer base_palette_mutex.unlock();
+    base_palette_override[idx] = .{
+        .r = @intCast(r & 0xff),
+        .g = @intCast(g & 0xff),
+        .b = @intCast(b & 0xff),
+    };
+    base_palette_has_any = true;
+}
+
+/// Clear all base palette overrides. Subsequent terminals revert to
+/// ghostty's hardcoded default palette.
+fn clearBasePalette() void {
+    base_palette_mutex.lock();
+    defer base_palette_mutex.unlock();
+    base_palette_override = .{null} ** 16;
+    base_palette_has_any = false;
+}
+
+/// If any base palette override is set, build a fresh `Palette` based on
+/// ghostty's defaults, patch in our 0-15 overrides, and call
+/// `changeDefault()` so the new defaults survive any future palette
+/// reset by the inner application.
+fn applyBasePaletteOverride(t: *ghostty_vt.Terminal) void {
+    base_palette_mutex.lock();
+    defer base_palette_mutex.unlock();
+    if (!base_palette_has_any) return;
+
+    var new_palette: color.Palette = color.default;
+    for (base_palette_override, 0..) |maybe_rgb, i| {
+        if (maybe_rgb) |rgb| new_palette[i] = rgb;
+    }
+    t.colors.palette.changeDefault(new_palette);
+}
