+test "renderer - synchronized output skips redundant cursor visibility on changed frames" {
+    const pool = gp.initGlobalPool(std.testing.allocator);
+    defer gp.deinitGlobalPool();
+    var local_link_pool = link.LinkPool.init(std.testing.allocator);
+    defer local_link_pool.deinit();
+
+    var cli_renderer = try CliRenderer.create(
+        std.testing.allocator,
+        12,
+        4,
+        pool,
+        true,
+    );
+    defer cli_renderer.destroy();
+
+    cli_renderer.terminal.caps.sync = true;
+    cli_renderer.terminal.setCursorPosition(3, 2, true);
+
+    const fg = ansi.rgbaFromFloats(1.0, 1.0, 1.0, 1.0);
+    const bg = ansi.rgbaFromFloats(0.0, 0.0, 0.0, 1.0);
+
+    try cli_renderer.getNextBuffer().drawText("A", 0, 0, fg, bg, 0);
+    cli_renderer.render(false);
+
+    try cli_renderer.getNextBuffer().drawText("B", 0, 0, fg, bg, 0);
+    cli_renderer.render(false);
+
+    const output = cli_renderer.getLastOutputForTest();
+    try std.testing.expect(std.mem.indexOf(u8, output, "B") != null);
+    try std.testing.expect(std.mem.indexOf(u8, output, ansi.ANSI.syncSet) != null);
+    try std.testing.expect(std.mem.indexOf(u8, output, ansi.ANSI.hideCursor) == null);
+    try std.testing.expect(std.mem.indexOf(u8, output, ansi.ANSI.showCursor) == null);
+}
