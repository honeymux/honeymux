+/// Single-entry thread-local cache for the perceptual alpha curve.
+///
+/// blendColors's perceptual alpha curve depends only on the overlay's alpha
+/// channel, but every translucent draw call (fillRect, drawTextBuffer,
+/// drawFrameBuffer, etc.) re-runs std.math.pow per cell with what is almost
+/// always a loop-invariant alpha for the duration of one call.  Caching the
+/// most recent (alpha → curve) pair collapses ~99% of those pow invocations
+/// for any caller drawing N consecutive cells with the same overlay alpha,
+/// without requiring per-call-site hoisting.
+///
+/// Initialized to a sentinel that no real alpha can hit (-1.0 < 0).  Stored
+/// thread-locally so multi-threaded renderers (if any) cannot race.
+threadlocal var perceptual_alpha_cache_key: f32 = -1.0;
+threadlocal var perceptual_alpha_cache_value: f32 = 0.0;
+
+inline fn perceptualAlphaCurve(alpha: f32) f32 {
+    if (alpha == perceptual_alpha_cache_key) {
+        return perceptual_alpha_cache_value;
+    }
+
+    var result: f32 = undefined;
+    // For high alpha values (>0.8), use a more aggressive curve
+    if (alpha > 0.8) {
+        const normalizedHighAlpha = (alpha - 0.8) * 5.0;
+        const curvedHighAlpha = std.math.pow(f32, normalizedHighAlpha, 0.2);
+        result = 0.8 + (curvedHighAlpha * 0.2);
+    } else {
+        result = std.math.pow(f32, alpha, 0.9);
+    }
+
+    perceptual_alpha_cache_key = alpha;
+    perceptual_alpha_cache_value = result;
+    return result;
+}
