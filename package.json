{
  "name": "honeymux",
  "version": "0.104.0",
  "module": "src/index.tsx",
  "scripts": {
    "build": "bun scripts/generate-takumi-shim.ts && bun build --compile --target bun src/index.tsx --outfile dist/hmx",
    "dev": "bun scripts/generate-takumi-shim.ts && bun --watch run src/index.tsx",
    "docs:screenshots": "bun run scripts/docs-screenshots.ts",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:semgrep": "docker run --rm -v \"$PWD:/src\" -w /src semgrep/semgrep@sha256:326e5f41cc972bb423b764a14febbb62bbad29ee1c01820805d077dd868fea48 semgrep scan --config=p/typescript --config=p/security-audit --error --metrics=off src/",
    "postinstall": "bun scripts/patches.ts apply && bun scripts/generate-takumi-shim.ts",
    "start": "bun scripts/generate-takumi-shim.ts && bun run src/index.tsx",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "0.2.1",
    "@opentui/react": "0.2.1",
    "ghostty-opentui": "1.4.11",
    "honeyshots": "github:honeymux/honeyshots",
    "react": "^19.2.5",
    "wcwidth": "^1.0.1"
  }
}
